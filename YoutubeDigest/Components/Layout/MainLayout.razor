@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Error">
        <MudIcon Icon="@Icons.Custom.Brands.YouTube" Class="mr-2" />
        <MudHidden Breakpoint="Breakpoint.Xs">
            <MudText Typo="Typo.h6" Style="font-weight:600; letter-spacing:.5px">YouTube Digest</MudText>
        </MudHidden>
        <MudHidden Breakpoint="Breakpoint.Xs" Invert="true">
            <MudText Typo="Typo.h6" Style="font-weight:600; letter-spacing:.5px">YD</MudText>
        </MudHidden>
        <MudSpacer />
        <MudButton Href="/" Color="Color.Inherit" Variant="Variant.Text" Class="mx-1">Analyse</MudButton>
        <MudButton Href="/dashboard" Color="Color.Inherit" Variant="Variant.Text" Class="mx-1">My Feed</MudButton>
        <MudIconButton Icon="@(IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@(() => IsDarkMode = !IsDarkMode)"
                       UserAttributes="@(new Dictionary<string, object> { ["title"] = IsDarkMode ? "Switch to light mode" : "Switch to dark mode" })" />
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="@($"Signed in as {context.User.Identity?.Name}")">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                                   Color="Color.Inherit"
                                   Href="/auth/logout"
                                   UserAttributes="@(new Dictionary<string, object> { ["title"] = "Sign out" })" />
                </MudTooltip>
            </Authorized>
            <NotAuthorized>
                <MudIconButton Icon="@Icons.Material.Filled.Login"
                               Color="Color.Inherit"
                               Href="/auth/login"
                               UserAttributes="@(new Dictionary<string, object> { ["title"] = "Sign in with Google" })" />
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool IsDarkMode { get; set; } = true;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#FF0000",
            AppbarBackground = "#CC0000",
            Background = "#F5F5F5",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#FF4444",
            AppbarBackground = "#CC0000",
            Background = "#121212",
            Surface = "#1E1E1E",
        }
    };
}
