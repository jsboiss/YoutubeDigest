@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Error">
        <MudIcon Icon="@Icons.Custom.Brands.YouTube" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight:600; letter-spacing:.5px">YouTube Digest</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@(() => _isDarkMode = !_isDarkMode)"
                       Title="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")" />
    </MudAppBar>
    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode = false;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#FF0000",
            AppbarBackground = "#CC0000",
            Background = "#F5F5F5",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#FF4444",
            AppbarBackground = "#CC0000",
            Background = "#121212",
            Surface = "#1E1E1E",
        }
    };
}
